# Copy this file to .env and fill in the values

# Database (SQLite for local, use a real DB URL for production)
DATABASE_URL="file:./dev.db"

# NextAuth — generate secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Your site URL (use https://yourdomain.com in production)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
